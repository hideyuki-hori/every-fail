---
import { getPosts } from '~/content.config'
import BaseLayout from '~/layouts/base-layout.astro'

const allPosts = await getPosts()

type PostWithAt = (typeof allPosts)[number] & { data: { at: Date } }

const posts = allPosts
  .filter(
    (post): post is PostWithAt =>
      post.data.kind !== 'issue' && 'at' in post.data
  )
  .filter(post => {
    const parts = post.id.split('/')
    return parts.length === 1 || parts[1] === 'index'
  })
  .map(post => {
    const parts = post.id.split('/')
    const slug = parts.length > 1 ? parts[0] : post.id
    return { ...post, slug }
  })
  .sort((a, b) => b.data.at.valueOf() - a.data.at.valueOf())
---

<BaseLayout title="Blog">
  <h1 class="mb-8 font-bold text-3xl">記事一覧</h1>
  <ul class="space-y-6">
    {posts.map((post) => (
      <li>
        <a href={`/${post.slug}`} class="block group">
          <article class="rounded-lg border border-gray-200 bg-white p-4 transition-colors hover:border-gray-300">
            <div class="flex items-center gap-2">
              <span class={`rounded px-2 py-0.5 text-xs ${
                post.data.kind === 'blog' ? 'bg-blue-100 text-blue-800' :
                post.data.kind === 'retro' ? 'bg-green-100 text-green-800' :
                post.data.kind === 'plan' ? 'bg-purple-100 text-purple-800' :
                'bg-gray-100 text-gray-800'
              }`}>
                {post.data.kind}
              </span>
              <time class="text-gray-500 text-sm">
                {post.data.at.toLocaleDateString('ja-JP')}
              </time>
            </div>
            <h2 class="mt-2 font-semibold text-xl transition-colors group-hover:text-blue-600">
              {post.data.title}
            </h2>
          </article>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
